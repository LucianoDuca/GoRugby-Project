# ─── Rugby API — api-sports.io ───────────────────────────────────────────────
# 1. Registrarse en https://dashboard.api-sports.io/register
# 2. Ir a Dashboard → API Key → copiar la key
# 3. Copiar este archivo como .env.local y pegar las keys
RUGBY_API_KEY=your_key_here

# ─── Highlightly (RapidAPI) ───────────────────────────────────────────────────
# 1. Registrarse en https://rapidapi.com
# 2. Buscar "Highlightly" → Subscribe al plan Free
# 3. Copiar la key de "x-rapidapi-key" y el host de "x-rapidapi-host"
HIGHLIGHTLY_API_KEY=your_rapidapi_key_here
HIGHLIGHTLY_API_HOST=highlightly.p.rapidapi.com
